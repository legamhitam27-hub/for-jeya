<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>For Jeya 💗</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&family=Great+Vibes&display=swap" rel="stylesheet">

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
background:linear-gradient(180deg,#ffd6e7,#ffc2dc,#ffb3d1);
overflow:hidden;
font-family:Poppins,sans-serif;
height:100vh;
display:flex;
justify-content:center;
align-items:center;
}

.container{
text-align:center;
padding:35px;
width:90%;
max-width:700px;
background:rgba(255,255,255,.18);
backdrop-filter:blur(12px);
border-radius:30px;
box-shadow:0 0 40px rgba(255,105,180,.3);
z-index:2;
}

h1{
font-family:"Great Vibes",cursive;
font-size:70px;
color:white;
margin-bottom:20px;
text-shadow:0 0 15px hotpink;
}

#typing{
color:white;
font-size:20px;
line-height:1.9;
min-height:250px;
white-space:pre-line;
}

button{
margin-top:30px;
padding:16px 40px;
border:none;
border-radius:50px;
font-size:18px;
cursor:pointer;
background:white;
color:#ff4d88;
font-weight:bold;
transition:.4s;
}

button:hover{
transform:scale(1.08);
}

</style>
</head>

<body>

<div class="container">
<h1>For Jeya 💗</h1>
<div id="typing"></div>

<button onclick="nextLetter()">
Open My Heart 💌
</button>
</div>

<script>
const pages = [
`hayy sayangnyaa nando!! 💞

website kecil ini nando buat cuma buat jeyy ajaa.

nando cuma mau ngungkapin isi hati nando dengan cara ini :)

mungkin sederhana, tapi setiap kata di sini ditulis penuh rasa sayang.

makasii yaa udah mau buka website kecil ini.

i hope you like it, sayanggg 🤍`,

`jeyy itu rumah buat nando.

tiap ngobrol sama jeyy, dunia nando jadi lebih tenang.

nando gak butuh yang sempurna, cukup jeyy aja udah lebih dari cukup 💗`,

`kalau nanti dunia lagi berat,
jangan lupa ada nando yang selalu sayang jeyy ya.

aku bakal selalu ada, walau cuma lewat kata-kata 🤍`
];

let index = 0;

function nextLetter(){
document.getElementById("typing").innerText = pages[index];

index++;
if(index >= pages.length){
index = 0;
}
}
</script>

</body>
</html>
